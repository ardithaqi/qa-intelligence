{
    "name": "qa-ci-intelligence",
    "version": "0.1.1",
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "description": "CI intelligence engine for test pipelines. Detects regressions, flaky tests, and failure lifecycle in pull requests.",
    "keywords": [
        "ci",
        "qa",
        "test-automation",
        "playwright",
        "regression-detection",
        "flaky-tests",
        "ci-intelligence"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ardithaqi/qa-ci-intelligence.git"
    },
    "type": "commonjs",
    "main": "dist/index.js",
    "bin": {
        "qa-ci-intelligence": "dist/cli/index.js",
        "qa-ci-analyze": "dist/cli/analyze.js",
        "qa-ci-diff": "dist/cli/diff.js",
        "qa-ci-history": "dist/cli/history.js",
        "qa-ci-comment": "dist/cli/postComment.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "prepare": "npm run build",
        "dev:diff": "ts-node src/cli/diff.ts --baseline baseline-artifacts --current artifacts --out failure-diff.json",
        "dev:comment": "ts-node src/cli/postComment.ts --diff failure-diff.json --repo owner/repo --pr 1 --token TOKEN"
    },
    "dependencies": {
        "@octokit/rest": "^22.0.1",
        "openai": "^6.29.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist"
    ]
}
